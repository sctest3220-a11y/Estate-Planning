# Copy to .env and fill in. Never commit the real .env.

# Required in production: a long random string that signs session cookies.
ESTATE_SECRET_KEY=change-me-to-a-long-random-string

# Where account credentials are stored (hashed passwords + acknowledgment only).
# Point at a writable volume in production.
ESTATE_USER_STORE=/data/users.json

# Optional: enable "Sign in with Google". Leave blank to hide the Google button.
# Create an OAuth 2.0 Web application client in Google Cloud Console and add the
# callback https://your-domain/auth/google/callback — see docs/Deployment.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
